{
  "schemaVersion": "1.0",
  "id": "prospective-atoms-eva-test-v1",
  "title": "Prospective ATOMS-EVA Test V1",
  "status": "preregistered",
  "scientificObjective": "Test whether the previously published ATOMS advantage over EVA replicates on a folio annotated after the protocol, models, metrics, and interpretation rules were frozen publicly.",
  "target": {
    "datasetCreatorImageId": 7,
    "datasetCreatorImageName": "page-007.jpg",
    "expectedFolio": "f3r",
    "identityMethod": "DatasetCreator image metadata plus PDF page to manuscript folio mapping: PDF page 7 corresponds to book page 5, therefore f3r.",
    "currentStatus": "annotation-in-progress",
    "unpublishedAndUnevaluated": true,
    "metadataInspectionOnly": true,
    "sequenceExportedBeforeCompletion": false,
    "metricsCalculatedBeforeCompletion": false
  },
  "frozenTrainingFolios": ["f1r", "f1v", "f47v"],
  "previouslyEvaluatedFolios": ["f2r", "f2v"],
  "testPolicy": {
    "newFolioRole": "test-only",
    "allowTrainingUpdate": false,
    "allowModelChanges": false,
    "allowAlignmentHeuristicChanges": false,
    "standaloneBeforePooled": true
  },
  "models": [
    {
      "id": "MODEL_0",
      "label": "Unigram",
      "features": ["symbol frequency only"]
    },
    {
      "id": "MODEL_1",
      "label": "Neighbors only",
      "features": ["immediate left neighbor", "immediate right neighbor"]
    },
    {
      "id": "MODEL_2",
      "label": "Neighbors plus coarse position",
      "features": ["immediate left neighbor", "immediate right neighbor", "coarse position: first_third, middle_third, final_third"]
    },
    {
      "id": "MODEL_3",
      "label": "Published V2 exact-length regression",
      "features": ["exact regional sequence length", "positional role", "immediate left neighbor", "immediate right neighbor"]
    },
    {
      "id": "MODEL_4",
      "label": "Neighbors plus coarse position and training-only length tertile",
      "features": ["immediate left neighbor", "immediate right neighbor", "coarse position", "length tertile computed from training regions only"]
    }
  ],
  "fixedParameters": {
    "smoothing": "Lidstone",
    "alpha": 0.5,
    "atomsVocabulary": ["a:1", "b:1", "c:1", "c:2", "d:1", "e:1", "f:1", "g:1", "h:1", "h:2", "i:1", "j:1", "k:1", "l:1", "m:1", "n:1"],
    "evaVocabularyHandling": "Same handling as REPRESENTATION-COMPARISON-V3-ABLATIONS: derive EVA vocabulary from configured train and evaluation regional symbol streams without changing model definitions.",
    "alignmentAlgorithm": "REPRESENTATION-ALIGNMENT-V1 monotonic regional alignment",
    "corruptionsPerTestRegion": 100
  },
  "primaryOutcome": {
    "metric": "combined normalized held-out log-loss",
    "model": "MODEL_1",
    "subset": "all aligned regions",
    "reason": "MODEL_1 showed a strong ATOMS advantage without exact regional length and tests transferable local structure with minimal representation-dependent features."
  },
  "secondaryOutcomes": [
    "MODEL_0 through MODEL_4 normalized log-loss",
    "top-1 accuracy",
    "unseen-context rate",
    "mean probability assigned to observed symbols",
    "real versus corrupted discrimination"
  ],
  "subsets": [
    "all",
    "medium",
    "medium_low_medium",
    "one_to_one",
    "exclude_unresolved_eva_lines"
  ],
  "interpretationRules": {
    "supportive": [
      "ATOMS has lower normalized log-loss than EVA in MODEL_1.",
      "The direction is also favorable in at least one higher-confidence subset.",
      "There are sufficient aligned opportunities to evaluate."
    ],
    "mixed": [
      "MODEL_1 favors ATOMS in the complete subset but not in higher-confidence subsets.",
      "Metrics disagree materially.",
      "The direction changes across major subsets."
    ],
    "negative": [
      "EVA has lower normalized log-loss than ATOMS in MODEL_1 with adequate coverage."
    ],
    "inconclusive": [
      "Insufficient EVA coverage.",
      "Insufficient aligned regions.",
      "Excessive unresolved alignment.",
      "The model cannot evaluate enough opportunities.",
      "Data integrity fails."
    ]
  },
  "notClaimed": [
    "decipherment",
    "global superiority",
    "optimality of ATOMS",
    "linguistic interpretation"
  ],
  "lockedRunner": "GrammarDiscoveryLab/scripts/prospective-atoms-eva-test-v1.js",
  "expectedOutputsAfterCompletion": [
    "GrammarDiscoveryLab/out/prospective-atoms-eva-test-v1/PROSPECTIVE-ATOMS-EVA-TEST-V1.md",
    "GrammarDiscoveryLab/out/prospective-atoms-eva-test-v1/folio-freeze-manifest.json",
    "GrammarDiscoveryLab/out/prospective-atoms-eva-test-v1/alignment-summary.tsv",
    "GrammarDiscoveryLab/out/prospective-atoms-eva-test-v1/model-results.tsv",
    "GrammarDiscoveryLab/out/prospective-atoms-eva-test-v1/subset-results.tsv",
    "GrammarDiscoveryLab/out/prospective-atoms-eva-test-v1/corruption-results.tsv",
    "GrammarDiscoveryLab/out/prospective-atoms-eva-test-v1/checksums.txt"
  ]
}
