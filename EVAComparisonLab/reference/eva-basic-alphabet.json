{
  "name": "Basic EVA",
  "expandedName": "Extensible Voynich Alphabet",
  "formerName": "European Voynich Alphabet",
  "authors": ["Gabriel Landini", "Rene Zandbergen"],
  "contributors": ["Jacques Guy"],
  "source": {
    "title": "Voynich MS - Text Analysis - Transliteration of the Text",
    "url": "https://www.voynich.nu/transcr.html",
    "notes": [
      "The source describes EVA as designed by Gabriel Landini and Rene Zandbergen with important contributions and suggestions from Jacques Guy.",
      "The source states that Basic Eva is the set of lower-case characters identified for the main transliteration alphabet.",
      "The source notes that EVA is not attempting to identify semantic units; it electronically represents shapes seen in the manuscript."
    ]
  },
  "font": {
    "name": "EVA2",
    "localReferencePath": "EVAComparisonLab/reference/eva-font/EVA2.ttf",
    "portalPath": "apps/portal/fonts/EVA2.ttf",
    "sourceUrl": "https://www.voynich.nu/Fonts/EVA2.ttf",
    "notes": [
      "The portal renders EVA glyphs with the official EVA2 font rather than spelling character-code notation in the UI.",
      "The downloaded EVA2 font maps Basic EVA glyphs onto the lowercase Latin transcription characters themselves."
    ]
  },
